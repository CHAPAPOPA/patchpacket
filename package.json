{
  "name": "patchpacket",
  "version": "0.2.0",
  "description": "Task-based context packer that turns stack traces into focused Markdown packets for AI coding assistants.",
  "main": "dist/index.js",
  "bin": {
    "patchpacket": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "prepack": "npm run build",
    "prepublishOnly": "npm test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "llm",
    "cli",
    "typescript",
    "developer-tools",
    "debugging",
    "stack-trace",
    "context-engineering",
    "prompt-engineering",
    "code-assistant"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CHAPAPOPA/patchpacket.git"
  },
  "bugs": {
    "url": "https://github.com/CHAPAPOPA/patchpacket/issues"
  },
  "homepage": "https://github.com/CHAPAPOPA/patchpacket#readme",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "tsx": "^4.20.5",
    "typescript": "^5.5.3",
    "vitest": "^4.1.10"
  }
}
